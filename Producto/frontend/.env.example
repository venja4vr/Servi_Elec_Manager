# ============================================================
# Variables de entorno para producción AWS
# Copiar este archivo a .env y rellenar valores reales.
# NO subir .env al repo (ya está en .gitignore).
# ============================================================

# Base de datos PostgreSQL (RDS de AWS)
DATABASE_URL=postgresql://postgres:CONTRASEÑA@servielec-db.xxxxxx.us-east-1.rds.amazonaws.com:5432/servielec_db

# WhatsApp Business (Meta)
WHATSAPP_TOKEN=tu-token-permanente-de-meta
WHATSAPP_PHONE_ID=tu-phone-id-de-whatsapp-business
VERIFY_TOKEN=servielec_verify_2026

# JWT del bot para autenticarse contra ms-gestion (dura 30 días)
MS_GESTION_TOKEN=tu-token-jwt-generado-con-login